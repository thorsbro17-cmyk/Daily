<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="DAILY">
<meta name="theme-color" content="#0a0a0a">
<title>DAILY</title>
<link rel="manifest" href="manifest.json">
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  :root {
    --bg: #0a0a0a;
    --surface: #141414;
    --border: #222;
    --text: #f0ede8;
    --muted: #555;
    --accent: #c8f55a;
    --accent-dim: #8aaa2a;
    --weekly: #7eb8f7;
    --done-text: #333;
    --radius: 14px;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
    min-height: 100dvh;
    padding: env(safe-area-inset-top, 20px) env(safe-area-inset-right, 0) env(safe-area-inset-bottom, 20px) env(safe-area-inset-left, 0);
    padding-top: max(env(safe-area-inset-top), 20px);
    padding-bottom: max(env(safe-area-inset-bottom), 32px);
    padding-left: 20px;
    padding-right: 20px;
    overscroll-behavior: none;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24px 0 20px;
  }

  .month-label {
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .day-label {
    font-size: 42px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--text);
  }

  .day-name {
    font-size: 14px;
    color: var(--muted);
    margin-top: 4px;
  }

  .progress-wrap {
    text-align: right;
  }

  .progress-count {
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1;
  }

  .progress-label {
    font-size: 12px;
    color: var(--muted);
    margin-top: 4px;
  }

  .progress-bar {
    width: 100%;
    height: 2px;
    background: var(--border);
    border-radius: 2px;
    margin-bottom: 24px;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 2px;
    transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .section-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 10px;
    margin-top: 24px;
    padding-left: 2px;
  }

  .checklist {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .item {
    display: flex;
    align-items: center;
    gap: 14px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 15px 16px;
    cursor: pointer;
    transition: all 0.2s ease;
    user-select: none;
    -webkit-user-select: none;
    position: relative;
    overflow: hidden;
  }

  .item:active {
    transform: scale(0.98);
    background: #1a1a1a;
  }

  .item.checked {
    border-color: #1e1e1e;
  }

  .item.checked .item-text {
    color: var(--done-text);
    text-decoration: line-through;
    text-decoration-color: #2a2a2a;
  }

  .item.weekly .check-circle {
    border-color: var(--weekly);
  }

  .item.weekly.checked .check-circle {
    background: var(--weekly);
    border-color: var(--weekly);
  }

  .item.checked .check-circle {
    background: var(--accent);
    border-color: var(--accent);
  }

  .check-circle {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }

  .check-circle svg {
    opacity: 0;
    transform: scale(0.5);
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .item.checked .check-circle svg {
    opacity: 1;
    transform: scale(1);
  }

  .item-text {
    font-size: 15px;
    font-weight: 400;
    line-height: 1.35;
    color: var(--text);
    transition: color 0.2s ease;
    flex: 1;
  }

  .weekly-badge {
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--weekly);
    background: rgba(126, 184, 247, 0.1);
    padding: 3px 7px;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .all-done {
    display: none;
    text-align: center;
    padding: 32px 0 16px;
  }

  .all-done.visible {
    display: block;
  }

  .all-done-emoji {
    font-size: 40px;
    margin-bottom: 10px;
  }

  .all-done-text {
    font-size: 16px;
    color: var(--accent);
    font-weight: 500;
  }

  .all-done-sub {
    font-size: 13px;
    color: var(--muted);
    margin-top: 4px;
  }

  .reset-btn {
    display: block;
    width: 100%;
    margin-top: 32px;
    padding: 14px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--muted);
    font-size: 13px;
    font-family: inherit;
    cursor: pointer;
    letter-spacing: 0.04em;
    transition: all 0.2s;
  }

  .reset-btn:active {
    color: var(--text);
    border-color: #444;
  }

  @media (prefers-reduced-motion: reduce) {
    .item, .check-circle, .check-circle svg, .progress-fill { transition: none; }
  }
</style>
</head>
<body>

<header>
  <div>
    <div class="month-label">July 2025</div>
    <div class="day-label" id="dayNum"></div>
    <div class="day-name" id="dayName"></div>
  </div>
  <div class="progress-wrap">
    <div class="progress-count"><span id="doneCount">0</span><span style="color:var(--muted);font-size:22px;font-weight:400"> / <span id="totalCount"></span></span></div>
    <div class="progress-label">today</div>
  </div>
</header>

<div class="progress-bar">
  <div class="progress-fill" id="progressFill" style="width:0%"></div>
</div>

<div class="section-label">Daily</div>
<div class="checklist" id="dailyList"></div>

<div class="section-label">Weekly</div>
<div class="checklist" id="weeklyList"></div>

<div class="all-done" id="allDone">
  <div class="all-done-emoji">✦</div>
  <div class="all-done-text">All done.</div>
  <div class="all-done-sub" id="allDoneSub"></div>
</div>

<button class="reset-btn" onclick="resetDay()">Reset today</button>

<script>
const DAILY = [
  "Draw something",
  "Read for 10 mins",
  "No shows before bed",
  "Take one photo",
  "Journal — thoughts + gratitude for 1 thing",
  "Leave one genuine comment while scrolling",
  "Text someone you haven't talked to in a while",
  "Listen to / read news · job search",
  "Do something active"
];

const WEEKLY = [
  { text: "Finance tracker — log all money spent this week", id: "finance" }
];

function getStorageKey(type) {
  const now = new Date();
  if (type === 'daily') {
    return `july_daily_${now.getFullYear()}_${now.getMonth()}_${now.getDate()}`;
  }
  if (type === 'weekly') {
    const dayOfWeek = now.getDay();
    const diff = now.getDate() - dayOfWeek;
    const weekStart = new Date(now.setDate(diff));
    return `july_weekly_${weekStart.getFullYear()}_${weekStart.getMonth()}_${weekStart.getDate()}`;
  }
}

function loadState(type) {
  try {
    const raw = localStorage.getItem(getStorageKey(type));
    return raw ? JSON.parse(raw) : {};
  } catch { return {}; }
}

function saveState(type, state) {
  try {
    localStorage.setItem(getStorageKey(type), JSON.stringify(state));
  } catch {}
}

let dailyState = loadState('daily');
let weeklyState = loadState('weekly');

function renderHeader() {
  const now = new Date();
  const days = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
  document.getElementById('dayNum').textContent = now.getDate();
  document.getElementById('dayName').textContent = days[now.getDay()];
}

function renderList() {
  const dailyEl = document.getElementById('dailyList');
  const weeklyEl = document.getElementById('weeklyList');
  dailyEl.innerHTML = '';
  weeklyEl.innerHTML = '';

  const totalItems = DAILY.length + WEEKLY.length;
  document.getElementById('totalCount').textContent = totalItems;

  DAILY.forEach((text, i) => {
    const checked = !!dailyState[i];
    const div = document.createElement('div');
    div.className = 'item' + (checked ? ' checked' : '');
    div.innerHTML = `
      <div class="check-circle">
        <svg width="12" height="9" viewBox="0 0 12 9" fill="none">
          <path d="M1 4L4.5 7.5L11 1" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="item-text">${text}</span>
    `;
    div.addEventListener('click', () => {
      dailyState[i] = !dailyState[i];
      saveState('daily', dailyState);
      renderList();
    });
    dailyEl.appendChild(div);
  });

  WEEKLY.forEach((item, i) => {
    const checked = !!weeklyState[i];
    const div = document.createElement('div');
    div.className = 'item weekly' + (checked ? ' checked' : '');
    div.innerHTML = `
      <div class="check-circle">
        <svg width="12" height="9" viewBox="0 0 12 9" fill="none">
          <path d="M1 4L4.5 7.5L11 1" stroke="#0a0a0a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <span class="item-text">${item.text}</span>
      <span class="weekly-badge">Weekly</span>
    `;
    div.addEventListener('click', () => {
      weeklyState[i] = !weeklyState[i];
      saveState('weekly', weeklyState);
      renderList();
    });
    weeklyEl.appendChild(div);
  });

  updateProgress();
}

function updateProgress() {
  const dailyDone = Object.values(dailyState).filter(Boolean).length;
  const weeklyDone = Object.values(weeklyState).filter(Boolean).length;
  const total = DAILY.length + WEEKLY.length;
  const done = dailyDone + weeklyDone;
  document.getElementById('doneCount').textContent = done;
  document.getElementById('progressFill').style.width = (done / total * 100) + '%';

  const allDoneEl = document.getElementById('allDone');
  if (done === total) {
    allDoneEl.classList.add('visible');
    const now = new Date();
    document.getElementById('allDoneSub').textContent = `${now.toLocaleDateString('en-US', {weekday:'long', month:'long', day:'numeric'})}`;
  } else {
    allDoneEl.classList.remove('visible');
  }
}

function resetDay() {
  if (confirm('Reset all of today\'s checks?')) {
    dailyState = {};
    saveState('daily', dailyState);
    renderList();
  }
}

renderHeader();
renderList();

setInterval(() => {
  const newKey = getStorageKey('daily');
  const storedKey = window._lastDailyKey;
  if (storedKey && storedKey !== newKey) {
    dailyState = {};
    renderList();
  }
  window._lastDailyKey = newKey;
}, 60000);
window._lastDailyKey = getStorageKey('daily');
</script>
</body>
</html>
